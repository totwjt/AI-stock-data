# Tushare 配置
# 获取 Token: https://tushare.pro/document/1?doc_id=39
TUSHARE_TOKEN=你的TushareToken

# 自定义 Tushare API 地址（可选）
TUSHARE_URL=http://lianghua.nanyangqiankun.top

# 数据库配置 (SQLite)
DATABASE_URL=sqlite+aiosqlite:///data/app.db

# PostgreSQL 配置 (数据同步模块使用)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tushare_sync
DB_USER=postgres
DB_PASSWORD=your_password

# 同步配置
BATCH_SIZE=1000
RETRY_TIMES=3
RETRY_DELAY=5

# 日志配置
LOG_LEVEL=INFO
